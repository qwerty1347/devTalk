# --- Gemini (Google AI Studio: https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=

# --- Pinecone (https://app.pinecone.io → API Keys) ---
PINECONE_API_KEY=
PINECONE_INDEX=devnotes

# --- Google Drive (서비스 계정) ---
# GCP 콘솔에서 서비스 계정을 만들고 JSON 키를 발급받은 뒤,
# 인덱싱할 Drive 폴더를 이 서비스 계정 이메일에 "공유"하세요.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# JSON 키의 private_key 값을 통째로 넣되, 줄바꿈은 \n 으로 한 줄로 두세요.
GOOGLE_PRIVATE_KEY=
# 인덱싱할 Drive 폴더의 ID (폴더 URL 끝의 문자열)
DRIVE_FOLDER_ID=